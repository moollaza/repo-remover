{
  "name": "repo-remover",
  "version": "2.0.0",
  "private": true,
  "description": "Bulk view, archive, and delete GitHub repositories. Zero-knowledge, client-side only.",
  "license": "MIT",
  "author": "Zaahir Moolla",
  "homepage": "https://reporemover.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/moollaza/repo-remover.git"
  },
  "bugs": {
    "url": "https://github.com/moollaza/repo-remover/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:cf": "bun run build && wrangler dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:fast": "playwright test --max-failures=1 --retries=0 --reporter=line",
    "test:e2e:debug": "playwright test --headed --max-failures=1 --retries=0 --timeout=0",
    "test:e2e:headed": "playwright test --headed --max-failures=1",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run test:unit && bun run test:e2e",
    "generate:og": "bun run scripts/generate-og-image.tsx",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-paginate-graphql": "^6.0.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@sentry/react": "^10.46.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fathom-client": "^3.7.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.13.2",
    "simple-icons": "^16.14.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.0",
    "@cloudflare/workers-types": "^4.20260413.1",
    "@octokit/graphql-schema": "^15.26.1",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/testing-library__user-event": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "prettier": "3.8.1",
    "satori": "^0.26.0",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,ts,tsx,css,md,json}": [
      "prettier --write"
    ]
  }
}
